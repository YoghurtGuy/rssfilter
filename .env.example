# --- LLM (OpenAI-compatible) ---
# Any provider exposing /chat/completions works (OpenAI, DeepSeek, local, ...).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Auth (single user) ---
# Password used to log in to the config UI.
APP_PASSWORD=change-me
# Secret used to sign the auth cookie. Set to a long random string.
# Falls back to APP_PASSWORD if unset.
APP_SECRET=

# --- Base URL ---
# Absolute origin used to build image-proxy URLs inside served feeds.
# Optional: derived from request headers if unset. Set on Vercel for stability.
APP_BASE_URL=

# --- Redis (Upstash, via Vercel Marketplace) ---
# Create "Upstash for Redis" in Vercel: Storage -> Create Database -> Marketplace.
# Connect it to the project, then `vercel env pull .env.local` to fetch these.
# The client (lib/kv.ts) accepts either the KV_REST_API_* or UPSTASH_REDIS_REST_* pair.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
